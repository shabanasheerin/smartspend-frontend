{
  "info": {
    "name": "SmartSpend AI",
    "description": "REST API collection for SmartSpend AI - Enterprise Expense Tracker SaaS",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080/api/v1" },
    { "key": "accessToken", "value": "" },
    { "key": "refreshToken", "value": "" },
    { "key": "categoryId", "value": "1" },
    { "key": "expenseId", "value": "1" },
    { "key": "incomeId", "value": "1" },
    { "key": "budgetId", "value": "1" },
    { "key": "goalId", "value": "1" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fullName\": \"Shab\",\n  \"email\": \"shab@example.com\",\n  \"password\": \"SecurePass123\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const data = pm.response.json().data;",
                  "if (data) { pm.collectionVariables.set('accessToken', data.accessToken); pm.collectionVariables.set('refreshToken', data.refreshToken); }"
                ]
              }
            }
          ]
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"shab@example.com\",\n  \"password\": \"SecurePass123\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const data = pm.response.json().data;",
                  "if (data) { pm.collectionVariables.set('accessToken', data.accessToken); pm.collectionVariables.set('refreshToken', data.refreshToken); }"
                ]
              }
            }
          ]
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/refresh",
            "body": { "mode": "raw", "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}" }
          }
        },
        {
          "name": "Logout",
          "request": { "method": "POST", "url": "{{baseUrl}}/auth/logout" }
        },
        {
          "name": "Change Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/change-password",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"currentPassword\": \"SecurePass123\",\n  \"newPassword\": \"NewSecurePass456\"\n}"
            }
          }
        },
        {
          "name": "Forgot Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/forgot-password",
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"shab@example.com\"\n}" }
          }
        },
        {
          "name": "Reset Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/reset-password",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"paste-token-from-email\",\n  \"newPassword\": \"NewSecurePass456\"\n}"
            }
          }
        },
        {
          "name": "Verify Email",
          "request": { "method": "GET", "url": "{{baseUrl}}/auth/verify-email?token=paste-token-from-email" }
        },
        {
          "name": "Resend Verification",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/resend-verification",
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"shab@example.com\"\n}" }
          }
        }
      ]
    },
    {
      "name": "Categories",
      "item": [
        { "name": "List Categories", "request": { "method": "GET", "url": "{{baseUrl}}/categories" } }
      ]
    },
    {
      "name": "Income",
      "item": [
        {
          "name": "Add Income",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/incomes",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 50000,\n  \"source\": \"SALARY\",\n  \"incomeDate\": \"2026-07-01\",\n  \"notes\": \"July salary\"\n}"
            }
          }
        },
        { "name": "Search Income", "request": { "method": "GET", "url": "{{baseUrl}}/incomes?page=0&size=20" } },
        { "name": "Get Income By Id", "request": { "method": "GET", "url": "{{baseUrl}}/incomes/{{incomeId}}" } },
        {
          "name": "Update Income",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/incomes/{{incomeId}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 52000,\n  \"source\": \"SALARY\",\n  \"incomeDate\": \"2026-07-01\",\n  \"notes\": \"July salary (revised)\"\n}"
            }
          }
        },
        { "name": "Delete Income", "request": { "method": "DELETE", "url": "{{baseUrl}}/incomes/{{incomeId}}" } }
      ]
    },
    {
      "name": "Expenses",
      "item": [
        {
          "name": "Add Expense",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/expenses",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"categoryId\": {{categoryId}},\n  \"amount\": 450.50,\n  \"expenseDate\": \"2026-07-03\",\n  \"notes\": \"Groceries\",\n  \"recurring\": false\n}"
            }
          }
        },
        { "name": "Search Expenses", "request": { "method": "GET", "url": "{{baseUrl}}/expenses?page=0&size=20" } },
        { "name": "Get Expense By Id", "request": { "method": "GET", "url": "{{baseUrl}}/expenses/{{expenseId}}" } },
        {
          "name": "Update Expense",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/expenses/{{expenseId}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"categoryId\": {{categoryId}},\n  \"amount\": 500,\n  \"expenseDate\": \"2026-07-03\",\n  \"notes\": \"Groceries (revised)\",\n  \"recurring\": false\n}"
            }
          }
        },
        { "name": "Delete Expense", "request": { "method": "DELETE", "url": "{{baseUrl}}/expenses/{{expenseId}}" } },
        {
          "name": "Upload Receipt",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/expenses/{{expenseId}}/receipts",
            "body": { "mode": "formdata", "formdata": [{ "key": "file", "type": "file", "src": "" }] }
          }
        },
        { "name": "List Receipts", "request": { "method": "GET", "url": "{{baseUrl}}/expenses/{{expenseId}}/receipts" } }
      ]
    },
    {
      "name": "Budgets",
      "item": [
        {
          "name": "Create Budget",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/budgets",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"categoryId\": {{categoryId}},\n  \"limitAmount\": 5000,\n  \"month\": 7,\n  \"year\": 2026\n}"
            }
          }
        },
        { "name": "List Budgets", "request": { "method": "GET", "url": "{{baseUrl}}/budgets?month=7&year=2026" } },
        { "name": "Delete Budget", "request": { "method": "DELETE", "url": "{{baseUrl}}/budgets/{{budgetId}}" } }
      ]
    },
    {
      "name": "Goals",
      "item": [
        {
          "name": "Create Goal",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/goals",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Buy Laptop\",\n  \"targetAmount\": 80000,\n  \"targetDate\": \"2026-12-31\"\n}"
            }
          }
        },
        { "name": "List Goals", "request": { "method": "GET", "url": "{{baseUrl}}/goals" } },
        {
          "name": "Contribute to Goal",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/goals/{{goalId}}/contribute",
            "body": { "mode": "raw", "raw": "{\n  \"amount\": 5000\n}" }
          }
        },
        { "name": "Delete Goal", "request": { "method": "DELETE", "url": "{{baseUrl}}/goals/{{goalId}}" } }
      ]
    },
    {
      "name": "Dashboard & Insights",
      "item": [
        { "name": "Dashboard Summary", "request": { "method": "GET", "url": "{{baseUrl}}/dashboard/summary" } },
        { "name": "AI Insights", "request": { "method": "GET", "url": "{{baseUrl}}/insights" } }
      ]
    },
    {
      "name": "Notifications",
      "item": [
        { "name": "List Notifications", "request": { "method": "GET", "url": "{{baseUrl}}/notifications?page=0&size=20" } },
        { "name": "Unread Count", "request": { "method": "GET", "url": "{{baseUrl}}/notifications/unread-count" } },
        { "name": "Mark Read", "request": { "method": "PATCH", "url": "{{baseUrl}}/notifications/1/read" } }
      ]
    },
    {
      "name": "Reports",
      "item": [
        { "name": "Get Report (JSON)", "request": { "method": "GET", "url": "{{baseUrl}}/reports?period=MONTHLY" } },
        { "name": "Export CSV", "request": { "method": "GET", "url": "{{baseUrl}}/reports/export/csv?period=MONTHLY" } },
        { "name": "Export Excel", "request": { "method": "GET", "url": "{{baseUrl}}/reports/export/excel?period=MONTHLY" } },
        { "name": "Export PDF", "request": { "method": "GET", "url": "{{baseUrl}}/reports/export/pdf?period=MONTHLY" } }
      ]
    },
    {
      "name": "Admin",
      "item": [
        { "name": "List Users", "request": { "method": "GET", "url": "{{baseUrl}}/admin/users?page=0&size=20" } },
        { "name": "Block User", "request": { "method": "PATCH", "url": "{{baseUrl}}/admin/users/2/block" } },
        { "name": "Unblock User", "request": { "method": "PATCH", "url": "{{baseUrl}}/admin/users/2/unblock" } },
        { "name": "Delete User", "request": { "method": "DELETE", "url": "{{baseUrl}}/admin/users/2" } },
        { "name": "Platform Stats", "request": { "method": "GET", "url": "{{baseUrl}}/admin/stats" } },
        { "name": "Audit Logs", "request": { "method": "GET", "url": "{{baseUrl}}/admin/audit-logs?page=0&size=20" } },
        {
          "name": "Create Category",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/admin/categories",
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Subscriptions\",\n  \"type\": \"EXPENSE\"\n}" }
          }
        },
        { "name": "Delete Category", "request": { "method": "DELETE", "url": "{{baseUrl}}/admin/categories/1" } }
      ]
    }
  ]
}
